    private void SNDIActionPerformed(java.awt.event.ActionEvent evt) {                                     
 String billno = SEARCH.getText().trim(); // Assuming you have a searchField

String url = "jdbc:mysql://localhost:3306/SELVAA_TRADERS";
String dbUser = "root";
String dbPassword = "Shreyaanivas@09";

try {
    Connection conn = DriverManager.getConnection(url, dbUser, dbPassword);
    PreparedStatement pst;

    if (billno.isEmpty()) {
        pst = conn.prepareStatement("SELECT * FROM SALES");
    } else {
        pst = conn.prepareStatement("SELECT * FROM SALES WHERE BILL_NO LIKE ?");
        pst.setString(1, "%" + billno + "%");
    }

    ResultSet rs = pst.executeQuery();

    DefaultTableModel model = (DefaultTableModel) jTable1.getModel();
    model.setRowCount(0); 

    boolean found = false;
    while (rs.next()) {
        found = true;
        model.addRow(new Object[]{
            rs.getString("BILL_NO"),
            rs.getString("DATE"),
            rs.getString("CUST_ID"),
            rs.getString("CUST_NAME"),
            rs.getString("PHONE_NO"),
            rs.getString("PRODUCT_NAME"),
            rs.getString("MATERIAL"),
            rs.getString("PAGES"),
            rs.getString("COST_PER_PIECE"),
            rs.getString("TOTAL_COST"),
            rs.getString("ORDER_SPECIFICATION")
        });
    }

    if (!found && !billno.isEmpty()) {
        JOptionPane.showMessageDialog(this, "No sales records found for: " + billno);
    }

    rs.close();
    pst.close();
    conn.close();
} catch (Exception e) {
    JOptionPane.showMessageDialog(this, "Error: " + e.getMessage());
}

    }                                    


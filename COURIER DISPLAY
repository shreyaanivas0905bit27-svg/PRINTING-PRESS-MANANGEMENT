    private void jButton4ActionPerformed(java.awt.event.ActionEvent evt) {                                         

        String courierAgency = SEARCH.getText().trim(); 

String url = "jdbc:mysql://localhost:3306/SELVAA_TRADERS";
String dbUser = "root";
String dbPassword = "Shreyaanivas@09";

try {
    Connection conn = DriverManager.getConnection(url, dbUser, dbPassword);
    PreparedStatement pst;

    if (courierAgency.isEmpty()) {
        pst = conn.prepareStatement("SELECT * FROM COURIER");
    } else {
        pst = conn.prepareStatement("SELECT * FROM COURIER WHERE COURIER_NO LIKE ?");
        pst.setString(1, "%" + courierAgency + "%");
    }

    ResultSet rs = pst.executeQuery();

    DefaultTableModel model = (DefaultTableModel) jTable1.getModel();
    model.setRowCount(0); 

    boolean found = false;
    while (rs.next()) {
        found = true;
        model.addRow(new Object[]{
            rs.getString("COURIER_NO"),
            rs.getString("COURIER_AGENCY"),
            rs.getString("COURIER_CHARGE"),
            rs.getString("PARCEL_NAZME"),
            rs.getString("PARCEL_ADDRESS")
        });
    }

    if (!found && !courierAgency.isEmpty()) {
        JOptionPane.showMessageDialog(this, "No courier found for agency: " + courierAgency);
    }

    rs.close();
    pst.close();
    conn.close();
} catch (Exception e) {
    JOptionPane.showMessageDialog(this, "Error: " + e.getMessage());
}

    }                                        


        String custName = SEARCH.getText().trim();

    String url = "jdbc:mysql://localhost:3306/SELVAA_TRADERS";
    String dbUser = "root";
    String dbPassword = "Shreyaanivas@09";

    try {
        Connection conn = DriverManager.getConnection(url, dbUser, dbPassword);
        PreparedStatement pst;
        
        if (custName.isEmpty()) {
            pst = conn.prepareStatement("SELECT * FROM TRANSACTIONS");
        } else {
            pst = conn.prepareStatement("SELECT * FROM TRANSACTIONS WHERE CUST_NAME LIKE ?");
            pst.setString(1, "%" + custName + "%");
        }

        ResultSet rs = pst.executeQuery();

        DefaultTableModel model = (DefaultTableModel) jTable1.getModel();
        model.setRowCount(0); 

        boolean found = false;
        while (rs.next()) {
            found = true;
            model.addRow(new Object[]{
                rs.getString("ORDER_NO"),
                rs.getString("ORDER_NAME"),
                rs.getString("CUST_NAME"),
                rs.getString("TOTAL_AMOUNT"),
                rs.getString("SENDER_NAME"),
                rs.getString("PHONE_NO"),
                rs.getString("DATE_OF_TRANSFERRED")
            });
        }

        if (!found && !custName.isEmpty()) {
            JOptionPane.showMessageDialog(this, "No transactions found for: " + custName);
        }

        rs.close();
        pst.close();
        conn.close();
    } catch (Exception e) {
        JOptionPane.showMessageDialog(this, "Error: " + e.getMessage());
    }
    }                                        


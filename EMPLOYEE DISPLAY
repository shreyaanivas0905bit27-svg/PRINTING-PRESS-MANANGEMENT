    private void jButton3ActionPerformed(java.awt.event.ActionEvent evt) {                                         
                                         
    String url = "jdbc:mysql://localhost:3306/SELVAA_TRADERS";
    String dbUser = "root";
    String dbPassword = "Shreyaanivas@09";

    try {
        Connection conn = DriverManager.getConnection(url, dbUser, dbPassword);
        String searchId = jTextField1.getText().trim(); // Get ID from search field
        String sql;
        PreparedStatement pstmt;
        if (searchId.isEmpty() || searchId.equalsIgnoreCase("SEARCH HERE USING ID")) {
            sql = "SELECT * FROM EMPLOYEE";
            pstmt = conn.prepareStatement(sql);
        } else {
            sql = "SELECT * FROM EMPLOYEE WHERE EMP_ID = ?";
            pstmt = conn.prepareStatement(sql);
            pstmt.setString(1, searchId);
        }
        ResultSet rs = pstmt.executeQuery();
        DefaultTableModel model = (DefaultTableModel) jTable1.getModel();
        model.setRowCount(0); 
        boolean found = false;
        while (rs.next()) {
            found = true;
            String empId = rs.getString("EMP_ID");
            String name = rs.getString("NAME");
            String phone = rs.getString("PHONE_NO");
            String email = rs.getString("EMAIL");
            String address = rs.getString("ADDRESS");  
            String salary = rs.getString("SALARY");
            if (salary == null) salary = "0.00";
           String experience = rs.getString("EXPERIENCE");
            if (experience == null) experience = "0.00";
            String designation = rs.getString("DESIGNATION");
            model.addRow(new Object[]{
                name, 
                empId, 
                phone, 
                email, 
                address, 
                Double.parseDouble(salary), 
                Double.parseDouble(experience), 
                designation
            });
        }
        if (!found) {
            JOptionPane.showMessageDialog(this, "No employee found with ID: " + searchId);
        }
        rs.close();
        pstmt.close();
        conn.close();
    } catch (Exception e) {
        JOptionPane.showMessageDialog(this, "Error: " + e.getMessage());
    }

    }                                        


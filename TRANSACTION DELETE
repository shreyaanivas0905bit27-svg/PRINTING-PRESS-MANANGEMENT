    private void FETCHActionPerformed(java.awt.event.ActionEvent evt) {                                      
        String materialName = SEARCH.getText().trim(); 
String url = "jdbc:mysql://localhost:3306/SELVAA_TRADERS";
String dbUser = "root";
String dbPassword = "Shreyaanivas@09";

try {
    Connection conn = DriverManager.getConnection(url, dbUser, dbPassword);
    PreparedStatement pst;

    if (materialName.isEmpty()) {
        pst = conn.prepareStatement("SELECT * FROM MATERIAL");
    } else {
        pst = conn.prepareStatement("SELECT * FROM MATERIAL WHERE PRODUCT_NAME LIKE ?");
        pst.setString(1, "%" + materialName + "%");
    }

    ResultSet rs = pst.executeQuery();
    DefaultTableModel model = (DefaultTableModel) jTable1.getModel();
    model.setRowCount(0); 
    boolean found = false;
    while (rs.next()) {
        found = true;
        model.addRow(new Object[]{
            rs.getString("PRODUCT_ID"),
            rs.getString("PRODUCT_NAME"),
            rs.getString("MATERIAL_NAME"),
            rs.getString("MATERIAL_COST")
             
        });
    }

    if (!found && !materialName.isEmpty()) {
        JOptionPane.showMessageDialog(this, "No material found for: " + materialName);
    }
    rs.close();
    pst.close();
    conn.close();
} catch (Exception e) {
    JOptionPane.showMessageDialog(this, "Error: " + e.getMessage());
}

    }                                     


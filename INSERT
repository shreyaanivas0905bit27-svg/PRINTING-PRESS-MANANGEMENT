    private void INSERTActionPerformed(java.awt.event.ActionEvent evt) {                                       
        String name = NAME.getText().trim();
    String phoneNo = PHONENO.getText().trim();
    String gst=GST.getText().trim();

    if (!phoneNo.matches("^[6-9]\\d{9}$")) {
        JOptionPane.showMessageDialog(this, "Phone number must be 10 digits and start with 6, 7, 8, or 9.");
        return;
    }

    if (!name.matches("^[A-Za-z ]+$")) {
        JOptionPane.showMessageDialog(this, "Name should not contain numbers or special characters.");
        return;
    }
    String url = "jdbc:mysql://localhost:3306/SELVAA_TRADERS";
    String dbUser = "root";
    String dbPassword = "Shreyaanivas@09";

    try {
        java.sql.Connection conn = DriverManager.getConnection(url, dbUser, dbPassword);
        String checkSql = "SELECT * FROM COUSTMER WHERE NAME = ? OR PHONE_NO = ?";
        PreparedStatement checkPst = conn.prepareStatement(checkSql);
        checkPst.setString(1, name);
        checkPst.setString(2, phoneNo);
        ResultSet rs = checkPst.executeQuery();
        if (rs.next()) {
            JOptionPane.showMessageDialog(this, "Customer already exists with the same Name or Phone Number.");
        } else {
            String insertSql = "INSERT INTO COUSTMER (NAME, PHONE_NO,GST) VALUES (?, ?,?)";
            PreparedStatement pst = conn.prepareStatement(insertSql, Statement.RETURN_GENERATED_KEYS);
            pst.setString(1, name);
            pst.setString(2, phoneNo);
            pst.setString(3,gst);
            int rowsInserted = pst.executeUpdate();
            if (rowsInserted > 0) {
                ResultSet generatedKeys = pst.getGeneratedKeys();
                if (generatedKeys.next()) {
                    int generatedId = generatedKeys.getInt(1);
                    JOptionPane.showMessageDialog(this, "Customer inserted successfully! New ID: " + generatedId);
                } else {
                    JOptionPane.showMessageDialog(this, "Customer inserted successfully!");
                }
            } else {
                JOptionPane.showMessageDialog(this, "Failed to insert customer.");
            }

            pst.close();
        }
        rs.close();
        checkPst.close();
        conn.close();
    } catch (Exception e) {
        e.printStackTrace();
        JOptionPane.showMessageDialog(this, "Error occurred: " + e.getMessage());
    } 

    }                                      


    private void deleteActionPerformed(java.awt.event.ActionEvent evt) {                                       
        // TODO add your handling code here:
        String billno = NAME.getText();
        if (billno.isEmpty()) {
            JOptionPane.showMessageDialog(this, "Please enter the material name  to delete.");
            return;
        }
        String empId = null;

        int confirm = JOptionPane.showConfirmDialog(this, "Are you sure you want to delete material: " + billno + "?", "Confirm Deletion", JOptionPane.YES_NO_OPTION);
        if (confirm != JOptionPane.YES_OPTION) {
            return;
        }

        String url = "jdbc:mysql://localhost:3306/SELVAA_TRADERS";
        String dbUser = "root";
        String dbPassword = "Shreyaanivas@09";

        String sql = "DELETE FROM MATERIAL WHERE PRODUCT_NAME = ?";

        try {
            Connection conn;
            conn = DriverManager.getConnection(url, dbUser, dbPassword);
            PreparedStatement pst = conn.prepareStatement(sql);
            pst.setString(1, billno);

            int rowsDeleted = pst.executeUpdate();
            if (rowsDeleted > 0) {
                JOptionPane.showMessageDialog(this, "MATERIAL deleted successfully.");

            } else {
                JOptionPane.showMessageDialog(this, "No MATERIAL found : " + billno);
            }

            pst.close();
            conn.close();
        } catch (Exception e) {
            e.printStackTrace();
            JOptionPane.showMessageDialog(this, "Error deleting order: " + e.getMessage());
        }
    }                                      


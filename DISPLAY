    private void SEARHCActionPerformed(java.awt.event.ActionEvent evt) {                                       
        String  id = search.getText().trim(); // Assuming you have a searchField
        String url = "jdbc:mysql://localhost:3306/SELVAA_TRADERS";
        String dbUser = "root";
        String dbPassword = "Shreyaanivas@09";
        try {
            Connection conn = DriverManager.getConnection(url, dbUser, dbPassword);
            PreparedStatement pst;
            if (id.isEmpty()) {
                pst = conn.prepareStatement("SELECT * FROM COUSTMER");
            } else {
                pst = conn.prepareStatement("SELECT * FROM COUSTMER WHERE ID LIKE ?");
                pst.setString(1, "%" + id + "%");
            }
            ResultSet rs = pst.executeQuery();
            DefaultTableModel model = (DefaultTableModel) jTable1.getModel();
            model.setRowCount(0); // Clear previous data
            boolean found = false;
            while (rs.next()) {
                found = true;
                model.addRow(new Object[]{
                    rs.getString("ID"),
                    rs.getString("NAME"),
                    rs.getString("PHONE_NO"),
                    rs.getString("GST")
                    
                    
                });
            }

            if (!found && !id.isEmpty()) {
                JOptionPane.showMessageDialog(this, "No sales records found for: " + id);
            }

            rs.close();
            pst.close();
            conn.close();
        } catch (Exception e) {
            JOptionPane.showMessageDialog(this, "Error: " + e.getMessage());
        }
    }                                      


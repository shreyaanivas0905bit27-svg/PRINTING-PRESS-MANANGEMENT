    private void jButton1ActionPerformed(java.awt.event.ActionEvent evt) {                                         
    String billNo = bill_no.getText();
    String billDate = bill_date.getText();
    String custId = cust_id.getText();
    String custName = cust_name.getText();
    String phoneNo = phone_no.getText();
    String gstNo = gst.getText();
    String productName = (String) product_name.getSelectedItem();
    String materialName = (String) material_name.getSelectedItem();
    String costText = cost_per_piece.getText();
    String quantityText = quantity.getText(); 
    double grandTotalWithAdditional = 0;
    String status=pending.getText();
    if (billDate.isEmpty() || custId.isEmpty() || custName.isEmpty() || phoneNo.isEmpty()
            || productName == null || materialName == null || costText.isEmpty() || quantityText.isEmpty()) {
        JOptionPane.showMessageDialog(this, "Please fill in all required fields.");
        return;
    }

    try {
        int quantity = Integer.parseInt(quantityText);
        double costPerPiece = Double.parseDouble(costText);
        double totalCost = quantity * costPerPiece;
        grandTotalWithAdditional = totalCost + 5630;

        Connection conn = DriverManager.getConnection("jdbc:mysql://localhost:3306/SELVAA_TRADERS", "root", "Shreyaanivas@09");
        PreparedStatement checkStmt = conn.prepareStatement("SELECT BILL_NO FROM SALES WHERE BILL_NO = ?");
        checkStmt.setString(1, billNo);
        ResultSet rs = checkStmt.executeQuery();
        if (rs.next()) {
            JOptionPane.showMessageDialog(this, "Duplicate BILL NO. Record already exists.");
            rs.close();
            checkStmt.close();
            conn.close();
            return;
        }
        String sql = "INSERT INTO SALES (BILL_NO, DATE, CUST_ID, CUST_NAME, PHONE_NO, PRODUCT_NAME, MATERIAL,PAGES, COST_PER_PIECE, TOTAL_COST, ORDER_SPECIFICATION, GST_NO, GRAND_TOTAL,status) VALUES (?,?,?,?,?,?,?,?,?,?,?,?,?,?)";
        PreparedStatement pst = conn.prepareStatement(sql);
        pst.setString(1, billNo);
        pst.setString(2, billDate);
        pst.setString(3, custId);
        pst.setString(4, custName);
        pst.setString(5, phoneNo);
        pst.setString(6, productName);
        pst.setString(7, materialName);
        pst.setString(8, quantityText);
        pst.setString(9, costText);
        pst.setDouble(10, totalCost);
        pst.setString(11, ""); // Order Specification placeholder
        pst.setString(12, gstNo);
        pst.setDouble(13, grandTotalWithAdditional);
         pst.setString(14,status);   

        int inserted = pst.executeUpdate();
        if (inserted > 0) {
            JOptionPane.showMessageDialog(this, "Sales record inserted successfully.");
        } else {
            JOptionPane.showMessageDialog(this, "Insert failed.");
        }

        pst.close();
        conn.close();

    } catch (NumberFormatException e) {
        JOptionPane.showMessageDialog(this, "Invalid number format in quantity or cost.");
    } catch (Exception e) {
        JOptionPane.showMessageDialog(this, "Error inserting sales record: " + e.getMessage());
        e.printStackTrace();
    }
    
   

    }                                        


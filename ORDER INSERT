    private void insertActionPerformed(java.awt.event.ActionEvent evt) {                                       
String orderDate = order_date.getText();
    String orderName = order_name.getText();
    String productName = (String) PRODUCT.getSelectedItem();
    String noOfProducts = no_of_products.getText();
    String deadline = order_deadline.getText();
    String totalAmount = order_total.getText();
    java.util.Date currentDate = new java.util.Date();
    java.text.SimpleDateFormat dateFormat = new java.text.SimpleDateFormat("yyyy-MM-dd");
    String currentDateString = dateFormat.format(currentDate);
    if (deadline.compareTo(currentDateString) < 0) {
        JOptionPane.showMessageDialog(this, "Deadline cannot be before the current date.");
        return;
    }
    
    try {
        String checkDuplicateQuery = "SELECT * FROM orders WHERE PRODUCT_NAME = ? AND NO_OF_PRODUCTS = ? AND DATE = ?";
        String url = "jdbc:mysql://localhost:3306/SELVAA_TRADERS"; 
        String dbUser = "root"; // Your database username
        String dbPassword = "Shreyaanivas@09";
       Connection conn = DriverManager.getConnection(url, dbUser, dbPassword);
       PreparedStatement pst = conn.prepareStatement(checkDuplicateQuery);
        pst.setString(1, productName);
        pst.setString(2, noOfProducts);
        pst.setString(3, orderDate);

        
        ResultSet rs = pst.executeQuery();
        if (rs.next()) {
            JOptionPane.showMessageDialog(this, "This order already exists for the same product, count, and order date.");
            rs.close();
            pst.close();
            conn.close();
            return; 
        }

        rs.close();
        pst.close();

        
        String sql = "INSERT INTO orders (DATE, ORDER_NAME, PRODUCT_NAME, NO_OF_PRODUCTS, DEADLINE, TOTAL) VALUES (?, ?, ?, ?, ?, ?)";

        
        pst = conn.prepareStatement(sql);

        pst.setString(1, orderDate);       
        pst.setString(2, orderName);
        pst.setString(3, productName);
        pst.setString(4, noOfProducts);    
        pst.setString(5, deadline);
        pst.setString(6, totalAmount);     
        int rowsAffected = pst.executeUpdate();

       
        if (rowsAffected > 0) {
            JOptionPane.showMessageDialog(this, "Order inserted successfully!");
        } else {
            JOptionPane.showMessageDialog(this, "Failed to insert order.");
        }

        
        pst.close();
        conn.close();
    } catch (Exception e) {
        e.printStackTrace();
        JOptionPane.showMessageDialog(this, "Error occurred while inserting order data: " + e.getMessage());
    }                  
    }                                      


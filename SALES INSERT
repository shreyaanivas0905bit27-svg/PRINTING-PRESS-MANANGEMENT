void fetchCostPerPiece() {
    String product = (String) product_name.getSelectedItem();
    String material = (String) material_name.getSelectedItem();
    if (product == null || material == null) return;

    try {
        Connection conn = DriverManager.getConnection("jdbc:mysql://localhost:3306/SELVAA_TRADERS", "root", "Shreyaanivas@09");
        PreparedStatement pst = conn.prepareStatement("SELECT MATERIAL_COST FROM MATERIAL WHERE PRODUCT_NAME=? AND MATERIAL=?");
        pst.setString(1, product);
        pst.setString(2, material);
        ResultSet rs = pst.executeQuery();
        if (rs.next()) {
            cost_per_piece.setText(String.valueOf(rs.getDouble("MATERIAL_COST")));
        } else {
            cost_per_piece.setText("");
        }
        conn.close();
    } catch (Exception e) {
        JOptionPane.showMessageDialog(this, "Error fetching cost: " + e.getMessage());
    }
}
private void generateBillNumber() {
    try {
        Connection conn = DriverManager.getConnection("jdbc:mysql://localhost:3306/SELVAA_TRADERS", "root", "Shreyaanivas@09");
        Statement stmt = conn.createStatement();
        ResultSet rs = stmt.executeQuery("SELECT MAX(BILL_NO) FROM SALES");
        int next = 1;
        if (rs.next() && rs.getString(1) != null) {
            next = Integer.parseInt(rs.getString(1)) + 1;
        }
        bill_no.setText(String.valueOf(next));
        conn.close();
    } catch (Exception e) {
        JOptionPane.showMessageDialog(this, "Error generating bill no: " + e.getMessage());
    }
}
private void loadProductNames() {
    try (Connection conn = DriverManager.getConnection("jdbc:mysql://localhost:3306/SELVAA_TRADERS", "root", "Shreyaanivas@09");
         Statement stmt = conn.createStatement();
         ResultSet rs = stmt.executeQuery("SELECT DISTINCT PRODUCT_NAME FROM MATERIAL")) {

        product_name.removeAllItems();
        while (rs.next()) {
            product_name.addItem(rs.getString("PRODUCT_NAME"));
        }
    } catch (Exception e) {
        JOptionPane.showMessageDialog(this, "Error loading product names: " + e.getMessage());
    }
}
private void loadMaterialsForProduct(String selectedProduct) {
    try (Connection conn = DriverManager.getConnection("jdbc:mysql://localhost:3306/SELVAA_TRADERS", "root", "Shreyaanivas@09");
         PreparedStatement pst = conn.prepareStatement("SELECT DISTINCT MATERIAL_NAME FROM MATERIAL WHERE PRODUCT_NAME = ?")) {

        pst.setString(1, selectedProduct);
        ResultSet rs = pst.executeQuery();

        material_name.removeAllItems();
        while (rs.next()) {
            material_name.addItem(rs.getString("MATERIAL_NAME"));
        }
    } catch (Exception e) {
        JOptionPane.showMessageDialog(this, "Error loading materials: " + e.getMessage());
    }
}
private void fetchMaterialCost() {
    String selectedProduct = (String) product_name.getSelectedItem();
    String selectedMaterial = (String) material_name.getSelectedItem();
    if (selectedProduct == null || selectedMaterial == null) return;

    try (Connection conn = DriverManager.getConnection("jdbc:mysql://localhost:3306/SELVAA_TRADERS", "root", "Shreyaanivas@09");
         PreparedStatement pst = conn.prepareStatement("SELECT MATERIAL_COST FROM MATERIAL WHERE PRODUCT_NAME = ? AND MATERIAL_NAME = ?")) {

        pst.setString(1, selectedProduct);
        pst.setString(2, selectedMaterial);
        ResultSet rs = pst.executeQuery();

        if (rs.next()) {
            cost_per_piece.setText(String.valueOf(rs.getDouble("MATERIAL_COST")));
        } else {
            cost_per_piece.setText("");
        }
    } catch (Exception e) {
        JOptionPane.showMessageDialog(this, "Error fetching cost: " + e.getMessage());
    }
}


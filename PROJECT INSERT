    private void INSERTActionPerformed(java.awt.event.ActionEvent evt) {                                       
    String proname=product.getText().trim();
    String materialName = MATNAME.getText().trim();   
    String materialCost = material_cost.getText().trim();    
    if (materialName.isEmpty()) {
        JOptionPane.showMessageDialog(this, "Material name cannot be empty!");
        return;
    }

    if (materialCost.isEmpty()) {
        JOptionPane.showMessageDialog(this, "Material cost cannot be empty!");
        return;
    }

    try {
        double cost = Double.parseDouble(materialCost);
        if (cost <= 0) {
            JOptionPane.showMessageDialog(this, "Material cost must be a positive number!");
            return;
        }
    } catch (NumberFormatException e) {
        JOptionPane.showMessageDialog(this, "Material cost must be a valid number!");
        return;
    }
    String url = "jdbc:mysql://localhost:3306/SELVAA_TRADERS";
    String dbUser = "root";
    String dbPassword = "Shreyaanivas@09";

    try {
        Connection conn = DriverManager.getConnection(url, dbUser, dbPassword);

        String checkSql = "SELECT * FROM material WHERE MATERIAL_NAME = ? AND PRODUCT_NAME=?";
        PreparedStatement checkPst = conn.prepareStatement(checkSql);
        checkPst.setString(1, materialName);
        checkPst.setString(2, proname);
        ResultSet rs = checkPst.executeQuery();
        if (rs.next()) {
            JOptionPane.showMessageDialog(this, "Material name already exists!");
            rs.close();
            checkPst.close();
            conn.close();
            return;
        }
        rs.close();
        checkPst.close();
        String insertSql = "INSERT INTO material (MATERIAL_NAME, MATERIAL_COST,PRODUCT_NAME) VALUES (?, ?,?)";
        PreparedStatement pst = conn.prepareStatement(insertSql);

        pst.setString(1, materialName);
        pst.setDouble(2, Double.parseDouble(materialCost)); 
        pst.setString(3, proname);

        int rowsInserted = pst.executeUpdate();

        if (rowsInserted > 0) {
            JOptionPane.showMessageDialog(this, "Material inserted successfully!");
            
        } else {
            JOptionPane.showMessageDialog(this, "Failed to insert material.");
        }

        pst.close();
        conn.close();
    } catch (Exception e) {
        e.printStackTrace();
        JOptionPane.showMessageDialog(this, "Error while inserting material: " + e.getMessage());
    }

    }                                      


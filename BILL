    private void GENERATEActionPerformed(java.awt.event.ActionEvent evt) {                                         
        String customerId = customerIdField.getText();
        try {
            Connection con = DriverManager.getConnection("jdbc:mysql://localhost:3306/SELVAA_TRADERS", "root", "Shreyaanivas@09");
            String sql = "SELECT * FROM COUSTMER WHERE ID = ?";
            PreparedStatement pst = con.prepareStatement(sql);
            pst.setString(1, customerId);
            ResultSet rs = pst.executeQuery();
            if (rs.next()) {
                S12.setText(rs.getString("NAME"));
                S2.setText(rs.getString("GST"));
            } else {
                JOptionPane.showMessageDialog(this, "Customer not found!");
            }
            rs.close();
            pst.close();
            con.close();
            LocalDate today = LocalDate.now();
            DateTimeFormatter formatter = DateTimeFormatter.ofPattern("dd-MM-yyyy");
            BILLDATE.setText(today.format(formatter));
        } catch (Exception e) {
            JOptionPane.showMessageDialog(this, "Error fetching customer details: " + e.getMessage());
        }

    }                                        

    private void ADDActionPerformed(java.awt.event.ActionEvent evt) {                                    
        String productName = (String) productComboBox.getSelectedItem();
        if (productName == null || productName.isEmpty()) {
            JOptionPane.showMessageDialog(this, "Please select a product!");
            return;
        }

        try {
            Connection con = DriverManager.getConnection("jdbc:mysql://localhost:3306/SELVAA_TRADERS", "root", "Shreyaanivas@09");
            String sql = "SELECT * FROM MATERIAL WHERE PRODUCT_NAME = ?";
            PreparedStatement pst = con.prepareStatement(sql);
            pst.setString(1, productName);
            ResultSet rs = pst.executeQuery();
            if (rs.next()) {
                float rate = rs.getFloat("MATERIAL_COST");
                int product = rs.getInt("PRODUCT_ID");
                String quantityStr = JOptionPane.showInputDialog(this, "Enter Quantity:");
                if (quantityStr == null || quantityStr.isEmpty()) {
                    JOptionPane.showMessageDialog(this, "Quantity is required!");
                    return;
                }
                int quantity = Integer.parseInt(quantityStr);
                float rupee = rate * quantity;
                  
                DefaultTableModel model = (DefaultTableModel) j1.getModel();
                 int sno = j1.getRowCount() + 1; 
                model.addRow(new Object[]{ sno,product,productName, quantity, rate, rupee});
               
            } else {
                JOptionPane.showMessageDialog(this, "Product not found!");
            }
            rs.close();
            pst.close();
            con.close();
        } catch (Exception e) {
            JOptionPane.showMessageDialog(this, "Error fetching product details: " + e.getMessage());
        }
    
    }                                   

    private void jButton2ActionPerformed(java.awt.event.ActionEvent evt) {                                         
        calculateGrandTotal();
        String filePath = null;
        try {
        java.awt.Rectangle rect = this.getBounds();
        java.awt.image.BufferedImage img = new java.awt.image.BufferedImage(rect.width, rect.height, java.awt.image.BufferedImage.TYPE_INT_RGB);
        this.paint(img.getGraphics());
        javax.swing.JFileChooser fileChooser = new javax.swing.JFileChooser();
        fileChooser.setDialogTitle("Save Bill as PDF");
        int userSelection = fileChooser.showSaveDialog(this);

        if (userSelection == javax.swing.JFileChooser.APPROVE_OPTION) {
            java.io.File fileToSave = fileChooser.getSelectedFile();
            filePath = fileToSave.getAbsolutePath();
            if (!filePath.endsWith(".pdf")) {
                filePath += ".pdf";
            }
            com.itextpdf.text.Document document = new com.itextpdf.text.Document();
            com.itextpdf.text.pdf.PdfWriter.getInstance(document, new java.io.FileOutputStream(filePath));
            document.open();
            java.io.ByteArrayOutputStream baos = new java.io.ByteArrayOutputStream();
            javax.imageio.ImageIO.write(img, "png", baos);
            com.itextpdf.text.Image image = com.itextpdf.text.Image.getInstance(baos.toByteArray());
            image.scaleToFit(document.getPageSize().getWidth() - 20, document.getPageSize().getHeight() - 20);
            image.setAlignment(com.itextpdf.text.Image.ALIGN_CENTER);
            document.add(image);
            document.close();

            javax.swing.JOptionPane.showMessageDialog(this, "Bill saved successfully as PDF!");
            showNotification("Bill Saved", "Your bill has been generated and saved successfully.");
        }
    } catch (Exception ex) {
        ex.printStackTrace();
        javax.swing.JOptionPane.showMessageDialog(this, "Error saving PDF: " + ex.getMessage());
    }

    private void FETCHActionPerformed(java.awt.event.ActionEvent evt) {                                      
        String url = "jdbc:mysql://localhost:3306/SELVAA_TRADERS";
        String dbUser = "root";
        String dbPassword = "Shreyaanivas@09";

        try {
            
            Connection conn = DriverManager.getConnection(url, dbUser, dbPassword);
            Statement stmt = conn.createStatement();
            String sql = "SELECT * FROM ORDERS";
            ResultSet rs = stmt.executeQuery(sql);

            DefaultTableModel model = (DefaultTableModel) jTable2.getModel();
            model.setRowCount(0); // Clear existing rows before adding new data
            while (rs.next()) {
                String empId = rs.getString("ORDER_NO");
                String name = rs.getString("DATE");
                String phone = rs.getString("ORDER_NAME");
                String email = rs.getString("PRODUCT_NAME");
                String address = rs.getString("NO_OF_PRODUCTS");
                String salary = rs.getString("DEADLINE");
                String experience = rs.getString("TOTAL");
                int empId = rs.getInt("ORDER_NO");
                String name = rs.getString("DATE");
                String phone = rs.getString("ORDER_NAME");
                String email = rs.getString("PRODUCT_NAME");
                int address = rs.getInt("NO_OF_PRODUCTS");
                String salary = rs.getString("DEADLINE");
                float experience = rs.getFloat("TOTAL");
              
                model.addRow(new Object[]{
                    
                    empId,
                    name,
                    phone,
                    email,
                    address,
                    salary, 
                    experience, 
                    
                });
            }
            rs.close();
            stmt.close();
            conn.close();
        } catch (Exception e) {
            JOptionPane.showMessageDialog(this, "Error: " + e.getMessage());
        }
    }                                     


    private void INSERTBUTTONActionPerformed(java.awt.event.ActionEvent evt) {                                                 
    String empName = emp_name.getText();
    String phoneNo = phone_no.getText();
    String emailText = email.getText();
    String addressText = address.getText();
    String experienceText = experience.getText();
    String designationText = designation.getText();
    String salaryText = salary.getText();
    if (empName.isEmpty() || phoneNo.isEmpty() || emailText.isEmpty() || 
        addressText.isEmpty() || experienceText.isEmpty() || designationText.isEmpty() || salaryText.isEmpty()) {
        JOptionPane.showMessageDialog(this, "All fields must be filled!");
        return;
    }
    if (!phoneNo.matches("[6789]\\d{9}")) {
        JOptionPane.showMessageDialog(this, "Phone number must start with 6, 7, 8, or 9 and be 10 digits long.");
        return;
    }
    if (salaryText.startsWith("0")) {
        JOptionPane.showMessageDialog(this, "Salary should not start with 0.");
        return;
    }
    try {
        int experienceValue = Integer.parseInt(experienceText);
        if (experienceValue > 50) {
            JOptionPane.showMessageDialog(this, "Experience should not exceed 50 years.");
            return;
        }
    } catch (NumberFormatException e) {
        JOptionPane.showMessageDialog(this, "Experience must be a valid number.");
        return;
    }
    String url = "jdbc:mysql://localhost:3306/SELVAA_TRADERS"; // Your database URL
    String dbUser = "root"; // Your database username
    String dbPassword = "Shreyaanivas@09"; // Your database password
    String sql = "INSERT INTO employee (NAME, PHONE_NO, EMAIL, ADDRESS, SALARY, EXPERIENCE, DESIGNATION) VALUES (?, ?, ?, ?, ?, ?, ?)";

    try {
        Connection conn = DriverManager.getConnection(url, dbUser, dbPassword);
        PreparedStatement pst = conn.prepareStatement(sql);
        pst.setString(1, empName);
        pst.setString(2, phoneNo);
        pst.setString(3, emailText);
        pst.setString(4, addressText);
        pst.setString(5, salaryText);
        pst.setString(6, experienceText);
        pst.setString(7, designationText);
        int rowsAffected = pst.executeUpdate();
        if (rowsAffected > 0) {
            JOptionPane.showMessageDialog(this, "Employee details inserted successfully!");
        } else {
            JOptionPane.showMessageDialog(this, "Failed to insert employee details.");
        }
        pst.close();
        conn.close();
    } catch (Exception e) {
        e.printStackTrace();
        JOptionPane.showMessageDialog(this, "Error occurred while inserting data.");
    }
        
    }                                            


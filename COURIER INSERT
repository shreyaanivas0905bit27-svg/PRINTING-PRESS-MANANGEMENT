    private void INSERTActionPerformed(java.awt.event.ActionEvent evt) {                                       
String courierAgency = courier_agency.getText().trim();
    String courierChargeStr = courier_charge.getText().trim();
    String parcelName = parcel_name.getText().trim();
    String parcelAddress = parcel_address.getText().trim();
    if (courierAgency.isEmpty() || courierChargeStr.isEmpty() || parcelName.isEmpty() || parcelAddress.isEmpty()) {
        JOptionPane.showMessageDialog(this, "All fields must be filled!");
        return;
    }
    long courierCharge;
    try {
        courierCharge = Long.parseLong(courierChargeStr);
        if (courierCharge <= 0) {
            JOptionPane.showMessageDialog(this, "Courier charge must be a positive number!");
            return;
        }
        if (courierChargeStr.startsWith("0")) {
            JOptionPane.showMessageDialog(this, "Courier charge should not start with 0!");
            return;
        }
    } catch (NumberFormatException e) {
        JOptionPane.showMessageDialog(this, "Courier charge must be a valid number!");
        return;
    }
    String url = "jdbc:mysql://localhost:3306/SELVAA_TRADERS";
    String dbUser = "root";
    String dbPassword = "Shreyaanivas@09";

    String sql = "INSERT INTO courier (COURIER_AGENCY, COURIER_CHARGE, PARCEL_NAME, PARCEL_ADDRESS) VALUES (?, ?, ?, ?)";

    try {
        Connection conn = DriverManager.getConnection(url, dbUser, dbPassword);
        PreparedStatement pst = conn.prepareStatement(sql);

        pst.setString(1, courierAgency);
        pst.setLong(2, courierCharge);
        pst.setString(3, parcelName);
        pst.setString(4, parcelAddress);

        int rowsInserted = pst.executeUpdate();

        if (rowsInserted > 0) {
            JOptionPane.showMessageDialog(this, "Courier details inserted successfully!");
        } else {
            JOptionPane.showMessageDialog(this, "Failed to insert courier details.");
        }

        pst.close();
        conn.close();
    } 
    catch (Exception e) {
        e.printStackTrace();
        JOptionPane.showMessageDialog(this, "SQL Error: " + e.getMessage());
    }
    }                                      


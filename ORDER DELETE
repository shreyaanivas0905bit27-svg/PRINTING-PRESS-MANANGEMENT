    private void deleteActionPerformed(java.awt.event.ActionEvent evt) {                                       
        // TODO add your handling code here:
        String ordId = id.getText();
        if (ordId.isEmpty()) {
            JOptionPane.showMessageDialog(this, "Please enter the order ID to delete.");
            return;
        }
        String empId = null;

        int confirm = JOptionPane.showConfirmDialog(this, "Are you sure you want to delete order with ID: " + empId + "?", "Confirm Deletion", JOptionPane.YES_NO_OPTION);
        if (confirm != JOptionPane.YES_OPTION) {
            return;
        }

        String url = "jdbc:mysql://localhost:3306/SELVAA_TRADERS";
        String dbUser = "root";
        String dbPassword = "Shreyaanivas@09";

        String sql = "DELETE FROM ORDERS WHERE ORDER_NO = ?";

        try {
            Connection conn;
            conn = DriverManager.getConnection(url, dbUser, dbPassword);
            PreparedStatement pst = conn.prepareStatement(sql);
            pst.setString(1, ordId);

            int rowsDeleted = pst.executeUpdate();
            if (rowsDeleted > 0) {
                JOptionPane.showMessageDialog(this, "order deleted successfully.");

            } else {
                JOptionPane.showMessageDialog(this, "No order found with ID: " + ordId);
            }

            pst.close();
            conn.close();
        } catch (Exception e) {
            e.printStackTrace();
            JOptionPane.showMessageDialog(this, "Error deleting order: " + e.getMessage());
        }
    }                                      


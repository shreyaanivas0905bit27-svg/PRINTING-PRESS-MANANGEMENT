    private void cust_nameFocusLost(java.awt.event.FocusEvent evt) {                                    
        
    String name = cust_name.getText().trim();
    if (name.isEmpty()) return;

    try {
        Connection conn = DriverManager.getConnection("jdbc:mysql://localhost:3306/SELVAA_TRADERS", "root", "Shreyaanivas@09");
        PreparedStatement pst = conn.prepareStatement("SELECT ID, PHONE_NO, GST FROM COUSTMER WHERE NAME = ?");
        pst.setString(1, name);
        ResultSet rs = pst.executeQuery();
        if (rs.next()) {
            cust_id.setText(rs.getString("ID"));
            phone_no.setText(rs.getString("PHONE_NO"));
            gst.setText(rs.getString("GST"));
        } else {
            cust_id.setText("");
            phone_no.setText("");
            gst.setText("");
            JOptionPane.showMessageDialog(null, "Customer not found.");
        }
        conn.close();
    } catch (Exception e) {
        JOptionPane.showMessageDialog(null, "Error fetching customer: " + e.getMessage());
    }

    }                                   

